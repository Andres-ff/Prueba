---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import Carousel from '../components/Carousel.astro';
---

<!doctype html>
<html lang="es">
<head>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />
<div class="container py-5">
	<h1 class="text-center mb-4">Carrusel de Imágenes</h1>
	<Carousel />
</div>
<Footer />
<script>
	// Cargar Bootstrap Bundle
	const script = document.createElement('script');
	script.src = "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js";
	script.integrity = "sha384-HoA0cKGLM7Q6UD5fFzMCgEIXJ2UXsMtxU4eKcHdhPYuVlyZ/OAGzMfUwku/i16y8";
	script.crossOrigin = "anonymous";
	document.head.appendChild(script);

	// Redirección de invite_token
	if (
		window.location.hash.includes('invite_token') &&
		!window.location.pathname.startsWith('/admin')
	) {
		window.location.href = '/admin/' + window.location.hash;
	}
</script>

</body>
</html>
